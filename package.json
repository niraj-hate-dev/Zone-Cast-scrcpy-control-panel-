{
  "name": "zone-cast",
  "version": "1.0.0",
  "description": "Professional Screen Mirroring",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.zonecast.app",
    "productName": "Zone Cast",
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      {
        "from": "./scrcpy-win64-v3.3.4",
        "to": "scrcpy-win64-v3.3.4",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3"
  }
}